generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Fase 0: schema base ──────────────────────────────────────────────────────
// Fase 1: adicionar User, Membership, Role, AuditLog, consent_log
// Fase 2: adicionar Lead, Account, Contact, Opportunity, Activity, Task, Pipeline, Stage, Note, Attachment

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  plan      String   @default("FREE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}
