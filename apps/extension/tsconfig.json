{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "jsx":              "react-jsx",
    "strict":           true,
    "noUnusedLocals":   true,
    "noImplicitAny":    true,
    "skipLibCheck":     true,
    "outDir":           "dist"
  },
  "include": ["src"]
}
